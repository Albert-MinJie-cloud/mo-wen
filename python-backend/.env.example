# ==========================================
# 应用配置
# ==========================================
APP_NAME=mo-wen
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# ==========================================
# MySQL 数据库配置
# ==========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=mo_wen
# 连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ==========================================
# Redis 配置
# ==========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# 连接池配置
REDIS_POOL_MAX_CONNECTIONS=20

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
